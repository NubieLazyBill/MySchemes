<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Базовая тема приложения -->
    <style name="Theme.MySchemes" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Основной цвет приложения -->
        <item name="colorPrimary">#4CAF50</item>
        <item name="colorPrimaryVariant">#388E3C</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Цвета для текста -->
        <item name="android:textColorPrimary">#2C3E50</item>
        <item name="android:textColorSecondary">#34495E</item>

        <!-- Цвет тулбара -->
        <item name="android:statusBarColor">#4CAF50</item>

        <!-- Стиль для текста в выпадающем меню -->
        <item name="android:itemTextAppearance">@style/MenuTextAppearance</item>
    </style>

    <!-- Стиль для текста меню -->
    <style name="MenuTextAppearance" parent="@android:style/TextAppearance.Widget.IconMenu.Item">
        <item name="android:textColor">#000000</item>
        <item name="android:textSize">16sp</item>
    </style>
</resources>