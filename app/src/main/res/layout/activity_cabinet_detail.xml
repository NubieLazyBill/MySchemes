<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Заголовок -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Данные шкафа"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:paddingBottom="8dp" />

        <!-- Основная информация -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/tvEquipmentName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Ячейка:"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvCellNumber"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Дата схемы:"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvLastRevisionDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="След. пересмотр:"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvNextRevisionDate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Статус:"
                        android:textStyle="bold" />
                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Редактируемые поля -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✏️ Редактирование"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Номер схемы">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSchemeNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Дата схемы (ДД.ММ.ГГГГ)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLastRevisionDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Дата следующего пересмотра (ДД.ММ.ГГГГ)">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etNextRevisionDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Чек-лист с фото -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="✅ Чек-лист проверки"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 1. Диспетчерское наименование -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbCabinetNameChecked"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📛 Диспетчерское наименование"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnCabinetNamePhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivCabinetNamePreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 2. ДН автоматов, рубильников -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbSwitchesNameChecked"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔌 ДН автоматов, рубильников"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnSwitchesNamePhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivSwitchesNamePreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 3. Инвентарный номер -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbInventoryNumberChecked"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔢 Инвентарный номер"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnInventoryNumberPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivInventoryNumberPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginVertical="8dp" />

                <!-- 4. Целостность замков -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbLockIntegrity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔒 Целостность замков"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnLockIntegrityPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivLockIntegrityPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 5. Уплотнение шкафа -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbSealIntegrity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📦 Уплотнение шкафа"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnSealIntegrityPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivSealIntegrityPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 6. Заходы кабелей -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbCableEntries"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔌 Заходы кабелей в защите"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnCableEntriesPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivCableEntriesPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 7. Нет оголённых жил -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbNoBareWires"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⚡ Нет оголённых жил"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnNoBareWiresPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivNoBareWiresPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 8. Адресные бирки -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbAddressLabels"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🏷️ Адресные бирки"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnAddressLabelsPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivAddressLabelsPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 9. Целостность клеммников -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbTerminalsIntegrity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔧 Целостность клеммников"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnTerminalsIntegrityPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivTerminalsIntegrityPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 10. Окраска -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbPainting"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🎨 Окраска"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnPaintingPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivPaintingPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 11. Обогрев -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbHeating"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔥 Обогрев"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnHeatingPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivHeatingPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- 12. Заземление -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <CheckBox
                        android:id="@+id/cbGrounding"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⛓️ Заземление"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnGroundingPhoto"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@android:drawable/ic_menu_camera"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="4dp" />

                    <ImageView
                        android:id="@+id/ivGroundingPreview"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:scaleType="centerCrop"
                        android:padding="2dp"
                        android:visibility="gone" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Общее фото шкафа -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📸 Общее фото шкафа"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnTakeGeneralPhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📷 Фото" />

            <Button
                android:id="@+id/btnViewGeneralPhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="👁️ Просмотр"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivGeneralPhotoPreview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:src="@android:drawable/ic_menu_camera"
            android:layout_marginBottom="16dp" />

        <!-- Кнопки действий -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="💾 Сохранить"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="🗑️ Удалить"
                android:backgroundTint="#F44336"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/btnBack"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="← Назад"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>