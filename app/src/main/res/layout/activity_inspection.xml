<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔧 Осмотр шкафа"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:paddingBottom="16dp" />

        <!-- Наименование шкафа -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Диспетчерское наименование шкафа">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etCabinetName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Состояние шкафа"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <!-- Чек-лист -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <CheckBox
                    android:id="@+id/cbLockIntegrity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔒 Целостность замков"
                    android:padding="8dp" />

                <CheckBox
                    android:id="@+id/cbSealIntegrity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📦 Уплотнение шкафа"
                    android:padding="8dp" />

                <CheckBox
                    android:id="@+id/cbCableEntries"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔌 Заходы кабелей в защите (уплотнение)"
                    android:padding="8dp" />

                <CheckBox
                    android:id="@+id/cbNoBareWires"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚡ Нет неподключённых оголённых жил"
                    android:padding="8dp" />

                <CheckBox
                    android:id="@+id/cbAddressLabels"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🏷️ Наличие адресных бирок"
                    android:padding="8dp" />

                <CheckBox
                    android:id="@+id/cbTerminalsIntegrity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔧 Целостность клеммников"
                    android:padding="8dp" />

                <CheckBox
                    android:id="@+id/cbPainting"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🎨 Окраска (без коррозии)"
                    android:padding="8dp" />

                <CheckBox
                    android:id="@+id/cbHeating"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔥 Обогрев (исправен)"
                    android:padding="8dp" />

                <CheckBox
                    android:id="@+id/cbGrounding"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⛓️ Заземление (наличие)"
                    android:padding="8dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Автоматы/рубильники -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Диспетчерские наименования автоматов, рубильников">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSwitchesName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:maxLines="3" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Инвентарный номер -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Инвентарный номер шкафа">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etInventoryNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Фото -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📸 Фото шкафа"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnTakePhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📷 Сделать фото" />

            <Button
                android:id="@+id/btnViewPhoto"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="👁️ Просмотр"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <ImageView
            android:id="@+id/ivPhotoPreview"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:src="@android:drawable/ic_menu_camera"
            android:layout_marginBottom="16dp" />

        <!-- Кнопки сохранения -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSaveInspection"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="💾 Сохранить осмотр"
                android:backgroundTint="#4CAF50" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="❌ Отмена"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

    </LinearLayout>

</ScrollView>